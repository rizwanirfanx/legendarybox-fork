      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>FAQ — Caffeine & Legends</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --brand:        #6B3FA0;\n    --brand-mid:    #8B5CC0;\n    --brand-light:  rgba(107, 63, 160, 0.08);\n    --brand-border: rgba(107, 63, 160, 0.22);\n    --ink:          #1C1A24;\n    --ink-mid:      #4A4460;\n    --ink-muted:    #7A7490;\n    --surface:      #FFFFFF;\n    --bg:           #F7F5F2;\n    --border:       rgba(0, 0, 0, 0.09);\n    --radius:       10px;\n    --font-display: 'Lora', Georgia, serif;\n    --font-body:    'DM Sans', system-ui, sans-serif;\n  }\n\n  body {\n    font-family: var(--font-body);\n    background: var(--bg);\n    color: var(--ink);\n    min-height: 100vh;\n    line-height: 1.6;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  /* ── page shell ── */\n  .page {\n    max-width: 760px;\n    margin: 0 auto;\n    padding: 64px 24px 100px;\n  }\n\n  /* ── header ── */\n  .page-header {\n    margin-bottom: 56px;\n    position: relative;\n  }\n\n\n\n  .page-header h1 {\n    font-family: var(--font-display);\n    font-size: clamp(32px, 5vw, 46px);\n    font-weight: 400;\n    line-height: 1.15;\n    color: var(--ink);\n    margin-bottom: 12px;\n  }\n\n  .page-header h1 em {\n    font-style: italic;\n    color: var(--brand);\n  }\n\n  .page-header p {\n    font-size: 16px;\n    color: var(--ink-muted);\n    max-width: 500px;\n    line-height: 1.6;\n  }\n\n  /* ── section ── */\n  .faq-section { margin-bottom: 44px; }\n\n  .faq-section-label {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-bottom: 12px;\n  }\n\n  .faq-section-label span {\n    font-size: 11px;\n    font-weight: 500;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: var(--brand);\n  }\n\n  .faq-section-label::after {\n    content: '';\n    flex: 1;\n    height: 0.5px;\n    background: var(--brand-border);\n  }\n\n  /* ── accordion list ── */\n  .faq-list {\n    display: flex;\n    flex-direction: column;\n    gap: 3px;\n  }\n\n  /* ── item ── */\n  details.faq-item {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    overflow: hidden;\n    transition: border-color 0.2s ease, box-shadow 0.2s ease;\n  }\n\n  details.faq-item[open] {\n    border-color: var(--brand-border);\n    box-shadow: 0 2px 16px rgba(107, 63, 160, 0.07);\n  }\n\n  details.faq-item summary {\n    list-style: none;\n    cursor: pointer;\n    padding: 16px 52px 16px 20px;\n    font-size: 15px;\n    font-weight: 500;\n    color: var(--ink);\n    position: relative;\n    user-select: none;\n    transition: color 0.15s ease;\n  }\n\n  details.faq-item summary::-webkit-details-marker { display: none; }\n\n  details.faq-item summary:hover { color: var(--brand); }\n\n  details.faq-item summary::after {\n    content: \"+\";\n    position: absolute;\n    right: 18px;\n    top: 50%;\n    transform: translateY(-50%);\n    font-size: 22px;\n    font-weight: 300;\n    color: var(--brand-mid);\n    line-height: 1;\n    font-family: var(--font-display);\n  }\n\n  details.faq-item[open] summary::after { content: \"–\"; }\n\n  .faq-body {\n    padding: 2px 20px 18px;\n    border-top: 1px solid var(--brand-border);\n    font-size: 14.5px;\n    line-height: 1.7;\n    color: var(--ink-mid);\n  }\n\n  .faq-body p { margin-top: 12px; }\n  .faq-body p:first-child { margin-top: 14px; }\n\n  .faq-body a {\n    color: var(--brand);\n    text-decoration: underline;\n    text-decoration-color: var(--brand-border);\n    text-underline-offset: 2px;\n    transition: text-decoration-color 0.15s ease;\n  }\n\n  .faq-body a:hover {\n    text-decoration-color: var(--brand);\n  }\n\n  /* ── footer note ── */\n  .faq-footer {\n    margin-top: 56px;\n    padding-top: 28px;\n    border-top: 1px solid var(--border);\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    flex-wrap: wrap;\n    gap: 12px;\n  }\n\n  .faq-footer p {\n    font-size: 13.5px;\n    color: var(--ink-muted);\n  }\n\n  .faq-footer a {\n    display: inline-block;\n    font-size: 13.5px;\n    font-weight: 500;\n    color: var(--brand);\n    text-decoration: none;\n    border: 1px solid var(--brand-border);\n    border-radius: 99px;\n    padding: 8px 18px;\n    transition: background 0.15s ease, border-color 0.15s ease;\n  }\n\n  .faq-footer a:hover {\n    background: var(--brand-light);\n    border-color: var(--brand-mid);\n  }\n\n  /* ── responsive ── */\n  @media (max-width: 560px) {\n    .page { padding: 44px 16px 80px; }\n    details.faq-item summary { font-size: 14px; padding: 14px 44px 14px 16px; }\n    .faq-body { font-size: 14px; padding: 2px 16px 16px; }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"page\">\n\n  <header class=\"page-header\">\n    <h1>Mind reading would be<br><em>an awesome ability.</em></h1>\n    <p>But since it's not possible, we've tried to answer as many questions as we could for you here in the F.A.Q. section.</p>\n  </header>\n\n  <!-- THE BOX -->\n  <section class=\"faq-section\">\n    <div class=\"faq-section-label\"><span>The box</span></div>\n    <div class=\"faq-list\">\n\n      <details class=\"faq-item\">\n        <summary>What is Caffeine and Legends?</summary>\n        <div class=\"faq-body\">\n          <p>A monthly book subscription box built around the reading ritual — each box pairs a curated book with a coffee, tea, or drinking chocolate to enjoy alongside it. We always include at least one book or drink-related item, and the box retail value exceeds what you pay every month.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>What's the difference between the monthly box and the Romantasy box?</summary>\n        <div class=\"faq-body\">\n          <p>The monthly box ships every month and may feature books with romantic subplots across a range of genres. The Romantasy box is quarterly — shipping in February, May, August, and November — and focuses exclusively on romantasy picks.</p>\n          <p>Its drinks and extras are curated specifically for that book and never overlap with the monthly box.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>What if I already own that month's book?</summary>\n        <div class=\"faq-body\">\n          <p>We focus on lesser-known titles (still amazing, just underappreciated). We send a secret link in our theme announcement newsletter so you can see the book before it ships. You're always welcome to <a href=\"https://legendarybox.com/pages/contact-us\">contact us</a> and we'll let you know the pick in advance.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Why don't you include a lot of bonus items?</summary>\n        <div class=\"faq-body\">\n          <p>Less is more. We'd rather send fewer, higher-quality items sourced from small businesses than fill a box with stuff you won't use. Everything in your box is something we'd be excited to receive ourselves.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>What if I have a food allergy?</summary>\n        <div class=\"faq-body\">\n          <p>We plan boxes 2–3 months in advance and are happy to share ingredient information ahead of shipping. If something that month doesn't work for you, we recommend skipping that box or swapping to a different drink option. We're a small team and can't special-order substitutions, but we do our best not to include common allergens.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Do you ship internationally?</summary>\n        <div class=\"faq-body\">\n          <p>International shipping is paused for now. Long transit times and high costs meant the experience wasn't up to our standards for customers outside the U.S. We're keeping an eye on options and will share updates if that changes.</p>\n        </div>\n      </details>\n\n    </div>\n  </section>\n\n  <!-- SUBSCRIBING -->\n  <section class=\"faq-section\">\n    <div class=\"faq-section-label\"><span>Subscribing</span></div>\n    <div class=\"faq-list\">\n\n      <details class=\"faq-item\">\n        <summary>How does the subscription work?</summary>\n        <div class=\"faq-body\">\n          <p>Sign up and you'll receive a box every month, shipping between the 1st and 7th. You can choose from multiple plans, including a roulette option that rotates between your drink preferences.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Do I have to subscribe, or can I buy a single box?</summary>\n        <div class=\"faq-body\">\n          <p>No commitment required. Single box purchases and seasonal boxes are listed under <a href=\"https://legendarybox.com/collections/shop-past-boxes\">Legendary Drops</a> around the 6th of each month. Subscribers do get a discount, though — so if you love your first box, it's worth coming back as a member.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Can I skip or pause a month?</summary>\n        <div class=\"faq-body\">\n          <p>Yes. Create an account at checkout and you can cancel, restart, or pause your monthly subscription at any time. If you're on a 3, 6, or 12-month pre-paid plan and need to skip, reach out via our contact form.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>How do I change my shipping address?</summary>\n        <div class=\"faq-body\">\n          <p>Update your address in both the shop and subscription sections of the site before the 15th of the month (renewal day). You can also <a href=\"https://legendarybox.com/pages/contact-us\">contact us</a> with the name on the subscription and we'll take care of it.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>I signed up but can't log in — help?</summary>\n        <div class=\"faq-body\">\n          <p>The account activation link likely landed in your spam or promotions folder (especially with Gmail). If you can't find it, just send us an email or fill out the contact form and we'll resend it right away.</p>\n        </div>\n      </details>\n\n    </div>\n  </section>\n\n  <!-- BILLING & CANCELLATION -->\n  <section class=\"faq-section\">\n    <div class=\"faq-section-label\"><span>Billing &amp; cancellation</span></div>\n    <div class=\"faq-list\">\n\n      <details class=\"faq-item\">\n        <summary>How much do the boxes cost?</summary>\n        <div class=\"faq-body\">\n          <p>Prices vary based on how many drinks you select and your subscription length. 3, 6, and 12-month pre-pay options are available at a discount. Check the <a href=\"https://legendarybox.com/#plan-selector\">plan selector</a> for current pricing.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Can I cancel anytime?</summary>\n        <div class=\"faq-body\">\n          <p>Yes — cancel any time before your renewal date on the 15th. If you cancel after renewal, that month's box will still ship. Cancelling a pre-paid plan stops future renewals but does not affect boxes you've already paid for.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Can I cancel an order I just placed?</summary>\n        <div class=\"faq-body\">\n          <p>Email us within 24 hours of purchase. All refunds may be subject to a 4% transaction fee.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Do you accept returns or offer refunds?</summary>\n        <div class=\"faq-body\">\n          <p>Due to the consumable nature of the items, we can't accept returns or issue refunds. If your box arrived damaged, email us at <a href=\"mailto:caffeineandlegends@gmail.com\">caffeineandlegends@gmail.com</a> with photos right away — we'll do everything we can to make it right.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>What happens if my box is returned to sender?</summary>\n        <div class=\"faq-body\">\n          <p>Let us know as soon as you see it in tracking. Returned orders are subject to a $5 reshipment fee to cover the cost of sending it again.</p>\n        </div>\n      </details>\n\n    </div>\n  </section>\n\n  <!-- REWARDS & GIFTS -->\n  <section class=\"faq-section\">\n    <div class=\"faq-section-label\"><span>Rewards &amp; gifts</span></div>\n    <div class=\"faq-list\">\n\n      <details class=\"faq-item\">\n        <summary>What are Kraken Rewards?</summary>\n        <div class=\"faq-body\">\n          <p>Our loyalty program — earn 1 point for every dollar spent, plus 50 bonus points on your birthday. You can also refer a friend: they get $10 off, and so do you. Access your points via the Kraken Rewards icon on the site once you're logged in.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>Can I send a box as a gift?</summary>\n        <div class=\"faq-body\">\n          <p>Yes — just enter the recipient's name and shipping address at checkout. We also offer <a href=\"https://legendarybox.com/products/caffeine-legends-digital-gift-card\">digital gift cards</a> if you'd rather let them choose.</p>\n        </div>\n      </details>\n\n    </div>\n  </section>\n\n  <!-- AUTHORS, VENDORS & INFLUENCERS -->\n  <section class=\"faq-section\">\n    <div class=\"faq-section-label\"><span>Authors, vendors &amp; influencers</span></div>\n    <div class=\"faq-list\">\n\n      <details class=\"faq-item\">\n        <summary>I'm an author — can my book be featured?</summary>\n        <div class=\"faq-body\">\n          <p>Congratulations on publishing! We're accepting submissions for 2026. <a href=\"https://docs.google.com/forms/d/e/1FAIpQLSdFRLLixU4UjhtMP5C1-7B2sbYDAdOBl4lk9k31J9aKIcgwBg/viewform\">Submit your book here.</a></p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>I'm a vendor — how do I get my products in the box?</summary>\n        <div class=\"faq-body\">\n          <p>We love sourcing from small businesses. Fill out our <a href=\"https://forms.gle/VhrK5epmPk25ZaWa6\">vendor application</a>. We're also on <a href=\"https://www.faire.com/apply/r/9v5rzfst1w\">Faire</a> — sign up through our link and we'll be notified.</p>\n        </div>\n      </details>\n\n      <details class=\"faq-item\">\n        <summary>I'm a blogger or influencer — can I get a box to review?</summary>\n        <div class=\"faq-body\">\n          <p>We do occasionally send review boxes and hold an Instagram rep search every three months. Follow us <a href=\"https://www.instagram.com/caffeineandlegends\">@caffeineandlegends</a> and apply when the next search opens.</p>\n        </div>\n      </details>\n\n    </div>\n  </section>\n\n  <!-- FOOTER -->\n  <div class=\"faq-footer\">\n    <p>Still have questions? We're happy to help.</p>\n    <a href=\"https://legendarybox.com/pages/contact-us\">Contact us →</a>\n  </div>\n\n</div>\n\n<script>\n  document.querySelectorAll('details.faq-item').forEach(item => {\n    item.addEventListener('toggle', () => {\n      if (item.open) {\n        document.querySelectorAll('details.faq-item').forEach(other => {\n          if (other !== item) other.removeAttribute('open');\n        });\n      }\n    });\n  });\n</script>\n\n</body>\n</html>",
